---
import { MediumZoom } from 'astro-pure/advanced'
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

// import SteamGameCard from '@/components/about/SteamGameCard.astro'

const headings = [
  { depth: 2, slug: 'hobbies', text: '爱好' },
  { depth: 2, slug: 'tools', text: '工具' },
  { depth: 2, slug: 'subscription', text: '订阅' },
  { depth: 2, slug: 'social-networks', text: '社交网络' },
  // { depth: 2, slug: 'gossips', text: 'Gossips' },
  { depth: 2, slug: 'about-blog', text: '关于博客' }
]
---

<PageLayout title='关于' {headings} view>
  <p>站点简介</p>
  <p>名称是为了备案临时起的🤪</p>
  <Button
    as='a'
    href='https://github.com/ljxme/friend-circle-lite/issues/new?template=%E9%82%AE%E7%AE%B1%E8%AE%A2%E9%98%85.md'
    title='订阅本站❤️'
    variant='ahead'
    class='not-prose'
    target='_blank'
    rel='noopener noreferrer'
  />
  <p>作者简介</p>
  <p>一个无聊无趣的人~🫥</p>
  <p>
    格言：无。 <Spoiler>一只闲云野鹤🪶~</Spoiler>
  </p>
  <Button title='赞助我😘' class='w-fit' href='/projects#sponsorship' variant='ahead' />

  {/* general-talk */}
  <h2 id='hobbies'>爱好</h2>
  <ul>
    <li>之前乐于读些闲书消磨时间</li>
    <li>现在乐于做些不知何意义的事蹉跎光阴</li>
    <li>未来乐于追忆现在的事回味过往时光</li>
  </ul>

  {/* <SteamGameCard id='ljxme' class='mt-4' /> */}

  {/* tools */}
  <h2 id='tools'>工具</h2>
  <p>当前所用的工具如下：</p>
  <!-- design tools
  <ToolSection
    class='mb-5'
    title='设计工具'
