      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='开发工具'
    tools={[
      {
        name: 'VS Code',
        description: 'IDE',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Trae',
