        icon: import('@/assets/tools/cursor.svg?raw')
      },
      {
        name: 'ChatGPT',
        description: 'AI Assistant',
        href: 'https://chat.openai.com/',
        icon: import('@/assets/tools/chatgpt.svg?raw')
      },
      {
        name: 'IntelliJ IDEA',
        description: 'Minecraft Mod Development',
