        href: 'https://www.adobe.com/products/aftereffects',
        icon: import('@/assets/tools/aftereffects.svg?raw')
      },
      {
        name: 'Premiere Pro',
        description: 'Video Editing',
        href: 'https://www.adobe.com/products/premiere',
        icon: import('@/assets/tools/premiere.svg?raw')
      }
    ]}
  />
  -->
  <ToolSection
    class='mb-5'
    title='生产力工具'
    tools={[
      {
        name: 'Zen',
        description: 'Browser',
        href: 'https://zen-browser.app/',
        icon: import('@/assets/tools/zenbrowser.svg?raw')
      },
      {
        name: 'Raycast',
