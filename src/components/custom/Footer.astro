---
import config from 'virtual:config'

import { getBlogCollection } from 'astro-pure/server'
import { Icon } from 'astro-pure/user'
import { getReadingTime } from 'astro-pure/utils'

const footerConf = config.footer

// Add RSS to social links if not already present
const social = [
  ...(footerConf.social || []),
  { icon: 'rss' as const, label: 'RSS', href: '/rss.xml' }
]

const footerLink1 = footerConf.links?.filter(({ pos }) => pos === 2) || []

const vercountItems = [
  { label: '∑ Visits', id: 'vercount_value_site_pv' },
  { label: '∑ Views', id: 'vercount_value_page_pv' },
  { label: '∑ Visitors', id: 'vercount_value_site_uv' }
]

// Word Count
const allPosts = await getBlogCollection()
const totalWords = allPosts.reduce((acc: number, post: any) => {
  return acc + getReadingTime(post.body).words
}, 0)

// Site Uptime
const siteStart = '2025-10-07T00:00:00'
---

<footer class='mx-auto mb-5 mt-16 w-full'>
  <div class='border-t pt-5'>
    <div class='flex items-center gap-y-3 max-sm:flex-col sm:justify-between sm:gap-y-0'>
      <div
        class='flex flex-col items-center sm:items-start gap-y-2 text-sm text-muted-foreground [&_a]:text-foreground'
      >
        <div class='flex flex-col sm:flex-row items-center sm:items-start gap-x-4 gap-y-2'>
          {/* Position 1 */}
          <div>
            {config.footer.year}
            {config.author}
            {
              footerConf.links && footerConf.links.length > 0 && (
                <>
                  &
                  <span>
                    {footerConf.links
                      .filter(({ pos }) => pos === 1)
                      .map(({ title, link, style }) => (
                        <span>
                          <a href={link} target='_blank' class={style}>
                            {title}
                          </a>
                        </span>
                      ))}
                  </span>
                </>
              )
            }
          </div>
          {
            footerConf.credits && (
              <span>
                <a href='https://github.com/withastro/astro' target='_blank'>
                  Astro
                </a>
                &
                <a href='https://github.com/cworld1/astro-theme-pure' target='_blank'>
                  Pure
                </a>
                theme powered
              </span>
            )
          }
        </div>
        {/* Position 2 */}
        {
          footerLink1.length > 0 && (
            <div>
              {footerLink1.map(({ title, link, style }, index) => (
                <span>
                  <a href={link} target='_blank' class={style}>
                    {title}
                  </a>
                  {index < footerLink1.length - 1 && ' | '}
                </span>
              ))}
            </div>
          )
        }
      </div>

      {/* Site Info */}
      <div class='flex flex-col gap-y-2 items-center sm:items-start'>
        {/* Detail Info */}
        <div class='flex items-center text-xs md:text-sm text-muted-foreground'>
          {/* Total Words */}
          <div class='flex items-center gap-x-1 px-4'>
            <span>∑ Words</span>
            <span id='total-words' class='font-medium text-foreground' data-raw={totalWords}>
              Loading…
            </span>
          </div>

          <div class='h-3 w-px bg-border'></div>

          {/* Total Uptime */}
          <div class='flex items-center gap-x-1 px-4'>
            <span>∑ Time</span>
            <span id='uptime' class='font-medium text-foreground'> Loading… </span>
          </div>
        </div>
        {/* Vercount Info */}
        <div class='flex items-center text-xs md:text-sm text-muted-foreground'>
          {
            vercountItems.map(({ label, id }, index) => (
              <>
                <div class='flex items-center gap-x-1 px-4'>
                  <span>{label}</span>
                  <span id={id} class='font-medium text-foreground'>
                    Loading…
                  </span>
                </div>

                {index < vercountItems.length - 1 && <div class='h-3 w-px bg-border' />}
              </>
            ))
          }
        </div>
      </div>

      <script define:vars={{ siteStart }} is:inline>
        // Shared count-up utility
        function countUp(el, target, duration = 1200) {
          const startTime = performance.now()
          function tick(now) {
            const elapsed = now - startTime
            const progress = Math.min(elapsed / duration, 1)
            const eased = 1 - Math.pow(1 - progress, 3)
            el.textContent = Math.floor(target * eased).toLocaleString()
            if (progress < 1) requestAnimationFrame(tick)
          }
          requestAnimationFrame(tick)
        }

        function parseCount(text) {
          if (!text) return NaN
          return parseInt(text.replace(/[,，]/g, ''), 10)
        }

        // ── 1. Total Words (static, animate on load) ──
        const wordsEl = document.getElementById('total-words')
        if (wordsEl) {
          const raw = parseInt(wordsEl.dataset.raw || '0', 10)
          if (raw > 0) countUp(wordsEl, raw, 1000)
        }

        // ── 2. Total Uptime (animate initial value, then live counter) ──
        const start = new Date(siteStart)
        const uptimeEl = document.getElementById('uptime')

        function formatUptime(seconds) {
          const d = Math.floor(seconds / 86400)
          const h = Math.floor((seconds % 86400) / 3600)
          const m = Math.floor((seconds % 3600) / 60)
          const s = Math.floor(seconds % 60)
          return `${d} d ${h} h ${m} m ${s} s`
        }

        if (uptimeEl) {
          const initialSeconds = Math.floor((Date.now() - start.getTime()) / 1000)
          let uptimeAnimating = true
          let animatedSeconds = initialSeconds

          // Animate from 0 to current uptime
          function tickUptime(now) {
            if (!uptimeAnimating) return
            const elapsed = now - animStart
            const progress = Math.min(elapsed / 1500, 1)
            const eased = 1 - Math.pow(1 - progress, 3)
            animatedSeconds = Math.floor(initialSeconds * eased)
            uptimeEl.textContent = formatUptime(animatedSeconds)
            if (progress < 1) {
              requestAnimationFrame(tickUptime)
            } else {
              uptimeAnimating = false
            }
          }
          const animStart = performance.now()
          requestAnimationFrame(tickUptime)

          // After animation, switch to live counter
          setInterval(() => {
            if (uptimeAnimating) return
            const diff = Math.floor((Date.now() - start.getTime()) / 1000)
            uptimeEl.textContent = formatUptime(diff)
          }, 1000)
        }

        // ── 3. Vercount numbers (async, animate when filled) ──
        ;(() => {
          const vercountIds = [
            'vercount_value_site_pv',
            'vercount_value_page_pv',
            'vercount_value_site_uv'
          ]
          vercountIds.forEach((id) => {
            const el = document.getElementById(id)
            if (!el) return

            const existing = parseCount(el.textContent?.trim() || '')
            if (!isNaN(existing) && existing > 0) {
              countUp(el, existing)
              return
            }

            const observer = new MutationObserver((_mutations, obs) => {
              const num = parseCount(el.textContent?.trim() || '')
              if (!isNaN(num) && num > 0) {
                obs.disconnect()
                countUp(el, num)
              }
            })
            observer.observe(el, { characterData: true, childList: true, subtree: true })
          })
        })()
      </script>

      {/* Social Brands */}
      <div class='flex items-center gap-x-4'>
        {
          social.map(({ icon, label, href }) => (
            <a
              class='inline-block text-muted-foreground transition-all hover:text-muted-foreground/75'
              href={href}
              aria-label={label}
            >
              <Icon name={icon} />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
